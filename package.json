  "main": "index.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test ts-node --transpile-only ./test/test-app.test.ts",
    "test:issue": "cross-env NODE_ENV=test ts-node --transpile-only ./test/issue.test.ts",
    "test:rn": "cross-env NODE_ENV=test ts-node --transpile-only ./test/rn.test.ts",
    "test:jira": "cross-env NODE_ENV=test ts-node --transpile-only ./test/jira.test.ts",
    "test:feishu": "cross-env NODE_ENV=test ts-node --transpile-only ./test/feishu.test.ts",
    "test:import": "cross-env NODE_ENV=test ts-node --transpile-only ./test/import.test.ts",
    "test:pbd-alert": "cross-env NODE_ENV=test ts-node --transpile-only ./test/pbd-alert.test.ts",
    "test:update-response-time": "cross-env NODE_ENV=test ts-node --transpile-only ./test/update-response-time.test.ts",
    "dev": "cross-env NODE_ENV=development ts-node --transpile-only src/app/server.ts",
    "build-qa": "rm -rf dist && cross-env NODE_ENV=qa tsc",
    "build": "rm -rf dist && cross-env NODE_ENV=production tsc",
    "build-production": "rm -rf dist && rm -rf ./.env && cp ./.env.production ./.env && cross-env NODE_ENV=production tsc",
    "build:windows": "rmdir /s /q dist && cross-env NODE_ENV=production tsc",
    "start": "cross-env NODE_ENV=production node dist/app/server.js",
    "cron:sla": "ts-node --transpile-only src/app/cron.ts",
    "cron:sla:full": "ts-node src/app/cron.ts full"
  },
