apiVersion: v1
kind: Secret
metadata:
  name: itsm-api-server-test-secret
  namespace: pbd-test
  labels:
    app: itsm-api-server-test
    environment: test
type: Opaque
stringData:
  # 数据库配置（从 .env.qa）
  DB_USER: "postgres"
  DB_PASSWORD: "your-db-password-here"

  # DB2 数据库配置（第二个数据库）
  DB2_USER: "postgres"
  DB2_PASSWORD: "your-db2-password-here"

  # Redis 配置
  REDIS_PASSWORD: "your-redis-password-here"

  # JWT Secret（从 .env.qa）
  JWT_SECRET: "your-secret-key-here"
  JWT_SECRET_ITOM: "your-itom-secret-key-here"

  # Jira 凭证（从 .env.qa）
  JIRA_ADMIN_USERNAME: "admin"
  JIRA_ADMIN_PASSWORD: "your-jira-password-here"
  JIRA_ADMIN_TOKEN: "your-jira-token-here"

  # 签名密钥（从 .env.qa）
  APP_SECRET_WEB: "your-web-secret-here"
  APP_SECRET_MOBILE: "your-mobile-secret-here"
  APP_SECRET_OPENAPI_RN: "your-openapi-rn-secret-here"

  # RN API 密钥
  RN_API_SECRET_KEY: "your-rn-api-secret-key-here"

  # Feishu 配置（从 .env.qa）
  FEISHU_APP_SECRET: "your-feishu-app-secret-here"

  # PBD Alert Token（从 .env.qa）
  PBD_ALERT_TOKEN: "your-pbd-alert-token-here"
