apiVersion: v1
kind: Secret
metadata:
  name: itsm-api-server-prod-secret
  namespace: pbd-services
  labels:
    app: itsm-api-server-prod
    environment: production
type: Opaque
stringData:
  # 数据库配置（生产环境 - 请填写真实密码）
  DB_USER: "postgres"
  DB_PASSWORD: "your-prod-db-password-here"

  # DB2 数据库配置（第二个数据库）
  DB2_USER: "postgres"
  DB2_PASSWORD: "your-prod-db2-password-here"

  # Redis 配置
  REDIS_PASSWORD: "your-prod-redis-password-here"

  # JWT Secret（生产环境 - 请使用强密钥）
  JWT_SECRET: "your-prod-secret-key-here-minimum-32-characters"
  JWT_SECRET_ITOM: "your-prod-itom-secret-key-here-minimum-32-characters"

  # Jira 凭证（生产环境）
  JIRA_ADMIN_USERNAME: "admin"
  JIRA_ADMIN_PASSWORD: "your-prod-jira-password-here"
  JIRA_ADMIN_TOKEN: "your-prod-jira-token-here"

  # 签名密钥（生产环境 - 请使用强密钥）
  APP_SECRET_WEB: "your-prod-web-secret-here"
  APP_SECRET_MOBILE: "your-prod-mobile-secret-here"
  APP_SECRET_OPENAPI_RN: "your-prod-openapi-rn-secret-here"

  # RN API 密钥
  RN_API_SECRET_KEY: "your-prod-rn-api-secret-key-here"

  # Feishu 配置（生产环境）
  FEISHU_APP_SECRET: "your-prod-feishu-app-secret-here"

  # PBD Alert Token（生产环境）
  PBD_ALERT_TOKEN: "your-prod-pbd-alert-token-here"
